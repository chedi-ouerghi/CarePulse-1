// =====================================================================
// CarePulse — Schéma Prisma complet
// apps/api/prisma/schema.prisma
//
// Couvre : authentification, profils patient/clinicien, ingestion de
// données quotidiennes, moteur clinique (timeline + règles), modèles ML
// (dépistage diabète + réadmission), les 2 agents IA, alertes, messagerie
// multi-canal (app/WhatsApp/SMS/voix), tâches de fond et audit.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

enum Role {
  PATIENT
  CLINICIAN
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum DiabetesType {
  TYPE_1
  TYPE_2
  GESTATIONAL
  PREDIABETES
  UNDIAGNOSED_SCREENING
  OTHER
}

enum ReadingSource {
  CGM
  GLUCOMETER
  MANUAL
  LAB
}

enum LifeEventType {
  MEAL
  ACTIVITY
  MEDICATION_INTAKE
  SYMPTOM
  MOOD
  STRESS
  SLEEP
  OBSERVATION
}

// Niveau de risque produit par les modèles ML (dépistage + réadmission)
// cf. compute_risk_level() / readmission_risk_level() dans agent/server.py
enum MlRiskLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

// Niveau de risque global produit par le moteur de règles cliniques
// cf. _compute_risk() dans agent/server.py (overall: low/medium/high)
enum ClinicalOverallRisk {
  LOW
  MEDIUM
  HIGH
}

enum AlertCategory {
  CLINICAL
  OPERATIONAL
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum MessageChannel {
  APP
  WHATSAPP
  SMS
  VOICE
  PUSH
  EMAIL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSenderType {
  PATIENT
  AI_AGENT
  CLINICIAN
  SYSTEM
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum ConversationAgent {
  CARE_ASSISTANT      // Agent 2 — Patient AI Coach (parle au patient)
  CLINICAL_ASSISTANT  // Support conversationnel côté clinicien, si activé
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ConsentType {
  DATA_PROCESSING
  AI_ANALYSIS
  WHATSAPP_MESSAGING
  SMS_MESSAGING
  VOICE_MESSAGING
}

enum AuditActorType {
  PATIENT
  CLINICIAN
  SYSTEM
  AI_AGENT
  ADMIN
}

// =====================================================================
// AUTH
// =====================================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient      Patient?
  clinician    Clinician?
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]

  @@index([role])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// =====================================================================
// PATIENT & CLINICIEN
// =====================================================================

model Clinician {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  licenseNumber  String?
  specialty      String?
  hospitalOrClinic String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patients            Patient[]         @relation("AssignedClinician")
  reviewedReports     ClinicalReport[]  @relation("ReportReviewedBy")
  acknowledgedAlerts  Alert[]           @relation("AlertAcknowledgedBy")
  conversations       Conversation[]    @relation("ClinicianConversations")
}

model Patient {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  dateOfBirth      DateTime?
  sex              Sex           @default(UNKNOWN)
  heightCm         Float?
  weightKg         Float?
  diabetesType     DiabetesType  @default(UNDIAGNOSED_SCREENING)
  diagnosisDate    DateTime?
  preferredLanguage String       @default("fr")
  timezone         String        @default("Europe/Paris")

  clinicianId      String?
  clinician        Clinician?    @relation("AssignedClinician", fields: [clinicianId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Ingestion de données quotidiennes
  glucoseReadings  GlucoseReading[]
  lifeEvents       LifeEvent[]
  labResults       LabResult[]
  medications      Medication[]

  // Contexte / jumeau numérique
  twinSnapshots    TwinSnapshot[]
  timelineEntries  ClinicalTimelineEntry[]

  // Moteur de risque (règles + ML)
  clinicalRiskAssessments ClinicalRiskAssessment[]
  diabetesRiskScores      DiabetesRiskScore[]
  readmissionRiskScores   ReadmissionRiskScore[]
  hospitalEncounters      HospitalEncounter[]

  // Agents IA
  clinicalAnalyses ClinicalAnalysis[]
  clinicalReports  ClinicalReport[]

  // Alertes & messagerie
  alerts            Alert[]
  conversations     Conversation[]
  channelAccounts   MessagingChannelAccount[]
  consents          Consent[]

  @@index([clinicianId])
}

// =====================================================================
// INGESTION DE DONNÉES QUOTIDIENNES
// =====================================================================

model GlucoseReading {
  id        String        @id @default(cuid())
  patientId String
  patient   Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  value     Float          // mg/dL
  source    ReadingSource  @default(MANUAL)
  takenAt   DateTime
  createdAt DateTime       @default(now())

  @@index([patientId, takenAt])
}

model LifeEvent {
  id         String        @id @default(cuid())
  patientId  String
  patient    Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type       LifeEventType
  occurredAt DateTime
  // Détails libres selon le type : repas (aliments/glucides), activité
  // (durée/intensité), humeur (échelle), symptôme (description), etc.
  payload    Json?
  createdAt  DateTime       @default(now())

  @@index([patientId, occurredAt])
  @@index([patientId, type])
}

model Medication {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name          String
  dosage        String
  frequency     String?
  startDate     DateTime?
  endDate       DateTime?
  prescribedBy  String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([patientId])
}

model LabResult {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  value     Float
  unit      String
  takenAt   DateTime
  createdAt DateTime @default(now())

  @@index([patientId, takenAt])
}

// =====================================================================
// CONTEXTE PATIENT / JUMEAU NUMÉRIQUE (Twin)
// =====================================================================

model TwinSnapshot {
  id                  String   @id @default(cuid())
  patientId           String
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  generatedAt         DateTime @default(now())
  avgGlucose          Float?
  glucoseVariance     Float?
  timeInRange         Float?
  hypoEvents          Int      @default(0)
  hyperEvents         Int      @default(0)
  dataCompleteness    Float?   // ratio de lectures attendues / reçues
  dataGaps            Json?
  anomalyFlags        Json?
  aiHistorySummary    String?  @db.Text

  @@index([patientId, generatedAt])
}

// Miroir persistant de TimelineEntry (agent/server.py) — utile pour
// l'audit et pour éviter de recalculer la timeline à chaque affichage.
model ClinicalTimelineEntry {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  time      DateTime?
  type      String   // "glucose" | "meal" | "activity" | "medication" | ...
  value     Float?
  detail    String?
  createdAt DateTime @default(now())

  @@index([patientId, time])
}

// =====================================================================
// MOTEUR DE RISQUE — RÈGLES CLINIQUES (agent/server.py: /clinical-rules)
// =====================================================================

model ClinicalRiskAssessment {
  id               String              @id @default(cuid())
  patientId        String
  patient          Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  computedAt       DateTime            @default(now())

  avgGlucose       Float
  glucoseVariance  Float
  timeInRange      Float
  hypoEvents       Int
  hyperEvents      Int
  mealFrequency    Float
  adherenceScore   Float

  hyperglycemia    Float
  hypoglycemia     Float
  adherence        Float
  lifestyle        Float
  overall          ClinicalOverallRisk

  timelineSummary  String              @db.Text

  alerts           Alert[]             @relation("AlertFromClinicalRisk")
  clinicalAnalyses ClinicalAnalysis[]  @relation("AnalysisFromClinicalRisk")

  @@index([patientId, computedAt])
}

// =====================================================================
// MOTEUR DE RISQUE — MODÈLES ML
// =====================================================================

// Modèle de dépistage du diabète (Random Forest sur Pima Indians Diabetes)
model DiabetesRiskScore {
  id                String      @id @default(cuid())
  patientId         String
  patient           Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  riskScore         Float       // probabilité 0-1
  riskLevel         MlRiskLevel
  modelVersion      String      @default("random_forest_v1")
  // Snapshot des variables d'entrée au moment du scoring
  inputFeatures     Json
  computedAt        DateTime    @default(now())

  @@index([patientId, computedAt])
}

// Séjour hospitalier source, alimentant le modèle de réadmission
// (cf. ReadmissionPatientFeatures dans agent/server.py)
model HospitalEncounter {
  id                     String    @id @default(cuid())
  patientId              String
  patient                Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  admissionTypeId        Int?
  dischargeDispositionId Int?
  admissionSourceId      Int?
  timeInHospital         Int?
  numLabProcedures       Int?
  numProcedures          Int?
  numMedications         Int?
  numberOutpatient       Int?
  numberEmergency        Int?
  numberInpatient        Int?
  diag1                  String?
  diag2                  String?
  diag3                  String?
  numberDiagnoses        Int?
  maxGluSerum            String?
  a1cResult              String?
  changeMade             String?
  diabetesMed            Boolean?
  readmitted             String?   // valeur brute source ("<30", ">30", "NO")

  // Flags des ~20 molécules du dataset UCI (metformin, glipizide, ...),
  // regroupés en JSON plutôt qu'en colonnes dédiées
  medicationStatus       Json?

  admittedAt             DateTime?
  dischargedAt           DateTime?
  createdAt              DateTime  @default(now())

  readmissionRiskScores  ReadmissionRiskScore[]

  @@index([patientId, admittedAt])
}

// Modèle de prédiction de réadmission à 30 jours (Random Forest équilibré
// sur UCI Diabetes 130-US Hospitals)
model ReadmissionRiskScore {
  id                  String              @id @default(cuid())
  patientId           String
  patient             Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  hospitalEncounterId String?
  hospitalEncounter   HospitalEncounter?  @relation(fields: [hospitalEncounterId], references: [id])
  riskScore           Float
  riskLevel           MlRiskLevel
  modelVersion        String              @default("readmission_rf_v1")
  inputFeatures        Json
  computedAt          DateTime            @default(now())

  @@index([patientId, computedAt])
}

// =====================================================================
// AGENTS IA
// =====================================================================

// Agent 1 — Clinical Intelligence Agent (ne parle jamais au patient)
model ClinicalAnalysis {
  id                        String                    @id @default(cuid())
  patientId                 String
  patient                   Patient                    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sourceClinicalRiskId       String?
  sourceClinicalRisk         ClinicalRiskAssessment?    @relation("AnalysisFromClinicalRisk", fields: [sourceClinicalRiskId], references: [id])

  patterns                  Json      // patterns détectés
  correlations               Json      // repas/activité/stress ↔ glycémie
  explanations               String    @db.Text
  aggravatingFactors          Json?
  confidenceLevel             Float     // 0-1
  recommendations             Json

  modelUsed                  String    @default("mistral-small-latest")
  generatedAt                 DateTime  @default(now())

  clinicalReports             ClinicalReport[]

  @@index([patientId, generatedAt])
}

// Agent 2 — AI Care Coordinator Agent (génère le rapport clinicien)
model ClinicalReport {
  id                   String            @id @default(cuid())
  patientId            String
  patient              Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalAnalysisId   String
  clinicalAnalysis     ClinicalAnalysis  @relation(fields: [clinicalAnalysisId], references: [id])

  summary              String            @db.Text
  fullReport           String            @db.Text
  priorities           Json
  recommendations      Json
  pointsToWatch        Json

  reviewedByClinicianId String?
  reviewedByClinician   Clinician?       @relation("ReportReviewedBy", fields: [reviewedByClinicianId], references: [id])
  reviewedAt            DateTime?

  generatedAt           DateTime         @default(now())

  @@index([patientId, generatedAt])
}

// =====================================================================
// ALERTES
// =====================================================================

model Alert {
  id                     String                   @id @default(cuid())
  patientId              String
  patient                Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sourceClinicalRiskId    String?
  sourceClinicalRisk      ClinicalRiskAssessment?  @relation("AlertFromClinicalRisk", fields: [sourceClinicalRiskId], references: [id])

  category                AlertCategory
  title                   String
  message                 String                   @db.Text
  severity                AlertSeverity

  triggeredAt             DateTime                 @default(now())
  acknowledgedByClinicianId String?
  acknowledgedByClinician   Clinician?             @relation("AlertAcknowledgedBy", fields: [acknowledgedByClinicianId], references: [id])
  acknowledgedAt            DateTime?
  resolvedAt                DateTime?

  notifications           AlertNotification[]

  @@index([patientId, triggeredAt])
  @@index([severity])
}

// Trace de diffusion d'une alerte sur un canal donné (SMS/WhatsApp/Push...)
model AlertNotification {
  id                 String          @id @default(cuid())
  alertId            String
  alert              Alert           @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channel            MessageChannel
  recipientUserId    String
  status             DeliveryStatus  @default(PENDING)
  providerMessageId  String?
  sentAt             DateTime?
  deliveredAt        DateTime?
  failReason         String?
  createdAt          DateTime        @default(now())

  @@index([alertId])
  @@index([recipientUserId, status])
}

// =====================================================================
// MESSAGERIE MULTI-CANAL (App / WhatsApp / SMS / Voix)
// =====================================================================

// Canaux activés par patient (numéro WhatsApp, numéro SMS, consentement)
model MessagingChannelAccount {
  id           String          @id @default(cuid())
  patientId    String
  patient      Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  channel      MessageChannel
  externalId   String          // numéro de téléphone / identifiant WhatsApp
  optedIn      Boolean         @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime        @default(now())

  @@unique([patientId, channel])
  @@index([externalId])
}

// Une conversation = un fil de discussion patient ↔ agent IA, sur un canal
model Conversation {
  id            String             @id @default(cuid())
  patientId     String
  patient       Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicianId   String?
  clinician     Clinician?         @relation("ClinicianConversations", fields: [clinicianId], references: [id])

  agent         ConversationAgent  @default(CARE_ASSISTANT)
  channel       MessageChannel     @default(APP)
  isActive      Boolean            @default(true)
  startedAt     DateTime           @default(now())
  lastMessageAt DateTime           @default(now())

  messages      Message[]

  @@index([patientId, channel])
}

model Message {
  id                String            @id @default(cuid())
  conversationId    String
  conversation      Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction         MessageDirection
  sender            MessageSenderType
  channel           MessageChannel

  contentText       String?           @db.Text
  audioUrl          String?           // note vocale entrante (patient)
  transcript        String?           @db.Text // sortie STT de audioUrl
  ttsAudioUrl        String?          // note vocale sortante (agent, TTS)

  status            DeliveryStatus    @default(PENDING)
  providerMessageId String?
  sentAt            DateTime?
  createdAt         DateTime          @default(now())

  @@index([conversationId, createdAt])
}

// =====================================================================
// OPÉRATIONS : TÂCHES DE FOND & AUDIT
// =====================================================================

model TaskTracker {
  id          String     @id @default(cuid())
  taskType    String     // ex: "risk-scoring", "clinical-analysis", "report-generation"
  status      TaskStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?    @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([taskType, status])
}

model AuditLog {
  id         String          @id @default(cuid())
  actorUserId String?
  actorUser   User?          @relation(fields: [actorUserId], references: [id])
  actorType   AuditActorType
  action      String         // ex: "ALERT_ACKNOWLEDGED", "REPORT_REVIEWED"
  entityType  String         // ex: "Alert", "ClinicalReport"
  entityId    String
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
}

model Consent {
  id          String      @id @default(cuid())
  patientId   String
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type        ConsentType
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?

  @@index([patientId, type])
}
